{
  "name": "delice-douja",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "env:supabase": "node scripts/init-supabase-env.mjs",
    "doctor": "node scripts/doctor.mjs",
    "check:db": "node scripts/check-supabase-tables.mjs",
    "db:apply": "node scripts/apply-schema.mjs",
    "db:setup": "node scripts/apply-schema.mjs && node scripts/check-supabase-tables.mjs",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "dev": "next dev",
    "dev:turbo": "next dev --turbo",
    "dev:clean": "npm run clean && npm run doctor && next dev",
    "dev:fresh": "npm run clean && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "jose": "^5.9.6",
    "next": "14.2.35",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "react": "^18",
    "react-dom": "^18",
    "resend": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^7.7.0",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  },
  "engines": {
  "node": "18.x"
}
}

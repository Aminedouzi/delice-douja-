# Base app config (copy to .env)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only: Project Settings → API → service_role (never expose to the browser).
# Required for admin product create/update/delete (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# One-time: create tables from your machine (npm run db:apply)
# Dashboard → Settings → Database → Connection string → URI (paste; replace [YOUR-PASSWORD])
# DATABASE_URL="postgresql://postgres.your-project-ref:YOUR_PASSWORD@aws-0-....pooler.supabase.com:6543/postgres"

# Admin panel (Next.js app, not Supabase Auth)
ADMIN_PASSWORD="change-me-strong-password"
ADMIN_JWT_SECRET="generate-a-long-random-secret-at-least-32-chars"

NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_CONTACT_EMAIL="contact@example.com"

# Order notifications (Formspree is the active sender in the current app)
FORMSPREE_ENDPOINT="https://formspree.io/f/your-form-id"
ORDER_NOTIFICATION_EMAIL="orders@example.com"

# Optional fallback values if you later wire Resend / SMTP again
RESEND_API_KEY="re_xxxxxxxx"
RESEND_FROM_EMAIL="Delice Douja <onboarding@resend.dev>"
